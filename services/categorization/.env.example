# Gemini API key — obtain one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional model override. Defaults to gemini-2.5-flash.
# Other options: gemini-2.5-pro (higher quality, slower/more expensive)
GEMINI_MODEL=gemini-2.5-flash

# Where the persistent SQLite taxonomy lives. Created on first run.
TAXONOMY_DB_PATH=./taxonomy.db
